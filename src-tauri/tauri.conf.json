{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnowledgeBase",
  "mainBinaryName": "KnowledgeBase",
  "version": "1.8.5",
  "identifier": "com.agilefr.kb",
  "build": {
    "beforeDevCommand": "pnpm dev:clean",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "知识库",
        "width": 1330,
        "height": 830,
        "minWidth": 1000,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "dragDropEnabled": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://fonts.gstatic.com data: blob:; media-src 'self' asset: http://asset.localhost blob:; connect-src 'self' http://localhost:* https://*; font-src 'self' data:; frame-src https://player.bilibili.com https://*.bilibili.com https://www.youtube.com https://www.youtube-nocookie.com https://v.qq.com https://*.qq.com https://player.youku.com https://*.youku.com https://player.vimeo.com https://*.vimeo.com https://player.twitch.tv https://*.twitch.tv https://www.dailymotion.com https://*.dailymotion.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://pub-9d9e6c0cb6934fb0a0c505e3c64f39b2.r2.dev/knowledge-base/update.json",
        "https://gitee.com/bkywksj/knowledge-base-release/raw/master/update.json",
        "https://github.com/bkywksj/knowledge-base-release/raw/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFODEzN0Y5RUM5NkJGQjIKUldTeXY1YnMrVGVCTHRZVHhya2liUXhYaCtscUt2cVlEWW40d0FNYWtORVhISU1uZEhtaWpSVjQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "deb",
      "appimage",
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown 文件",
        "description": "由知识库打开",
        "role": "Editor"
      }
    ],
    "copyright": "Copyright (c) 2026 AgileFR",
    "category": "Productivity",
    "shortDescription": "本地知识库桌面应用",
    "longDescription": "基于 Tauri 构建的本地知识库管理工具，支持 Markdown 编辑、全文搜索、双向链接、知识图谱、AI 问答等功能。",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "SimpChinese",
          "English"
        ],
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0"
        ],
        "section": "utility"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
